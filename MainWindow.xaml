<Window x:Class="NBALegende.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NBALegende"
        mc:Ignorable="d"
        Title="NBA Legende - Prijava"
        Height="1000"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
  
    
    <Grid Background="Transparent">
        <Grid Width="902"
              Height="760"
              HorizontalAlignment="Left"
              VerticalAlignment="Top" RenderTransformOrigin="0.922,0.636" Margin="242,32,0,0">

            <!--ajmo zvezdalee-->
            <Polygon Points="450,20 540,210 750,235 595,395 640,630 450,525 260,630 305,395 150,235 360,210"
                    Fill="#D8BE7D"
                    Stroke="#A68349"
                    StrokeThickness="4"
                    HorizontalAlignment="Left"
                    Margin="-26,89,0,37"
                    RenderTransformOrigin="0.086,0.522">
                <Polygon.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1.35" ScaleY="1.35"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform X="-109.293" Y="4.882"/>
                    </TransformGroup>
                </Polygon.RenderTransform>

                <Polygon.Effect>
                    <DropShadowEffect BlurRadius="18"
                          ShadowDepth="6"
                          Opacity="0.35"/>
                </Polygon.Effect>
            </Polygon>

            <!--sadrzaj-->
            <StackPanel Width="320"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,-5,0,0">

               
                <!--nbacrni-->
                <Image Source="Images/nba-logo_2x.png"
                       Width="230"
                       Height="172"
                       Stretch="Uniform"
                       />

                <!--naslopv-->
                <TextBlock Text="NBA PRIJAVA"
                           FontSize="40"
                           FontFamily="Times New Roman"
                           FontWeight="Bold"
                           Foreground="#1B1B1B"
                           HorizontalAlignment="Center" RenderTransformOrigin="0.518,0.494"/>

                <TextBlock Text="DOBRODOŠLI NAZAD!"
                           FontSize="18"
                           FontFamily="Times New Roman"
                           Foreground="#1B1B1B"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,22"/>

                <!--username-->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="Korisničko ime"
                               FontSize="15"
                               FontFamily="Times New Roman"
                               Foreground="#1B1B1B"
                               Margin="30,0,0,4"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="1"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="&#xE77B;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="#1B1B1B"/>

                        <Grid Grid.Row="0" Grid.Column="1">
                            <TextBox x:Name="tbUsername"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="16"
                                     VerticalContentAlignment="Center"
                                     Foreground="#333333"
                                     GotFocus="tbUsername_GotFocus"
                                     LostFocus="tbUsername_LostFocus"
                                     TextChanged="tbUsername_TextChanged"/>

                            <TextBlock x:Name="tbUsernamePlaceholder"
                                       Text="Unesite vaše korisničko ime"
                                       Foreground="#6E6E6E"
                                       FontSize="16"
                                       FontFamily="Times New Roman"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Margin="2,0,0,0"/>
                        </Grid>

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="2"
                                BorderBrush="#59534A"
                                BorderThickness="0,0,0,1"/>
                    </Grid>
                </StackPanel>

               
                <!--sifra-->
                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Lozinka"
                        FontSize="15"
                        FontFamily="Times New Roman"
                        Foreground="#1B1B1B"
                        Margin="30,0,0,4"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="1"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="&#xE72E;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="20"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="#1B1B1B"/>

                        <Grid Grid.Row="0" Grid.Column="1">
                            <PasswordBox x:Name="pbPassword"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    FontSize="16"
                                    Padding="0"
                                    GotFocus="pbPassword_GotFocus"
                                    LostFocus="pbPassword_LostFocus"
                                    PasswordChanged="pbPassword_PasswordChanged"/>

                            <TextBox x:Name="tbPasswordVisible"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    FontSize="16"
                                    Visibility="Collapsed"
                                    GotFocus="tbPasswordVisible_GotFocus"
                                    LostFocus="tbPasswordVisible_LostFocus"
                                    TextChanged="tbPasswordVisible_TextChanged"/>

                            <TextBlock x:Name="pbPasswordPlaceholder"
                                    Text="Unesite vašu lozinku"
                                    Foreground="#6E6E6E"
                                    FontSize="16"
                                    FontFamily="Times New Roman"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False"
                                    Margin="2,0,0,0"/>
                            </Grid>

                        <Border Grid.Row="1"
                            Grid.ColumnSpan="2"
                            BorderBrush="#59534A"
                            BorderThickness="0,0,0,1"/>
                    </Grid>
                </StackPanel>

                <TextBlock x:Name="txtTogglePassword"
                    Text="Prikaži lozinku"
                    FontSize="14"
                    FontFamily="Times New Roman"
                    ToolTip="Prikaz ili sakrivanje lozinke"  
                    TextDecorations="Underline"
                    Foreground="#1B1B1B"
                    Cursor="Hand"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,22"
                    MouseLeftButtonDown="txtTogglePassword_MouseLeftButtonDown"/>

                <!--prijava-->
                <Button x:Name="btnLogin"
                        Content="PRIJAVI SE"
                        Width="240"
                        Height="42"
                        Margin="0,0,0,14"
                        HorizontalAlignment="Center"
                        ToolTip="Prijava na sistem"
                        Background="#2C66B8"
                        Foreground="White"
                        FontSize="18"
                        FontFamily="Times New Roman"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnLogin_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8"
                                                      ShadowDepth="2"
                                                      Opacity="0.25"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!--gasi-->
                <Button x:Name="btnExit"
                        Content="IZAĐI"
                        Width="240"
                        Height="42"
                        HorizontalAlignment="Center"
                        Background="#D92C41"
                        Foreground="White"
                        ToolTip="Gasenje totalno"
                        FontSize="18"
                        FontFamily="Times New Roman"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        
                        Click="btnExit_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8"
                                                      ShadowDepth="2"
                                                      Opacity="0.25"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>


        </Grid>
    </Grid>
</Window>