<Window x:Class="NBALegende.LegendsTableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NBALegende"
        mc:Ignorable="d"
        Title="NBA Legende"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#EEE7D6">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Times New Roman"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#D8BE7D"/>
            <Setter Property="Foreground" Value="#1B1B1B"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderBrush" Value="#A68349"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#1B1B1B"/>
            <Setter Property="Background" Value="#F8F2E3"/>
            <Setter Property="BorderBrush" Value="#D6CCB5"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#F8F2E3"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2E3BA"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8D39A"/>
                    <Setter Property="Foreground" Value="#1B1B1B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Width="1040"
                Height="570"
                Background="#F8F2E3"
                CornerRadius="30"
                BorderBrush="#A68349"
                BorderThickness="3"
                Padding="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!--naslov-->
                <TextBlock Grid.Row="0"
                           Text="NBA LEGENDE"
                           FontSize="42"
                           FontWeight="Bold"
                           Foreground="#1B1B1B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,18"/>

                <!--redgore-->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="cbSelectAll"
                              Grid.Column="0"
                              Content="Označi sve"
                              Cursor="Hand"
                              FontSize="17"
                              ToolTip="Označavanje svih legendi u tabeli"
                              Foreground="#1B1B1B"
                              VerticalAlignment="Center"
                              Margin="6,0,0,0"
                              Checked="cbSelectAll_Checked"
                              Unchecked="cbSelectAll_Unchecked"/>

                    <TextBlock Grid.Column="2"
                               Text="Pregled svih NBA legendi"
                               FontSize="17"
                               Foreground="#5B5242"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                </Grid>

                <!--tabela-->
                <DataGrid x:Name="dgLegends"
                          Grid.Row="2"
                          Width="990"
                          AutoGenerateColumns="False"
                          SelectionUnit="FullRow"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="70"
                          Background="#F8F2E3"
                          BorderBrush="#A68349"
                          BorderThickness="2"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="0,0,0,18">

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Obriši" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                                    HorizontalAlignment="Center"
                                                                                                    VerticalAlignment="Center"
                                                                                                    ToolTip="Izaberi brata"
                                                                                                    Cursor="Hand"
                                                                                                    Focusable="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Ime igrača" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="16"
                                               ToolTip="Kliknite za pregled detalja"
                                               TextAlignment="Center">
                                        <Hyperlink Click="LegendHyperlink_Click"
                                                   Tag="{Binding}"
                                                   Foreground="#2C66B8">
                                            <Run Text="{Binding FullName}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Slika" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Image Source="{Binding ResolvedImagePath}"
                                               Width="90"
                                               Height="55"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Datum dodavanja"
                                            Width="220"
                                            IsReadOnly="True"
                                            Binding="{Binding DateAdded, StringFormat=dd.MM.yyyy. HH:mm}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!--dugmnici-->
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,6,0,0">

                    <Button x:Name="btnAdd"
                            Content="DODAJ"
                            Width="140"
                            Height="45"
                            Margin="0,0,12,0"
                            ToolTip="Dodavanje nove legende"
                            Background="#2C66B8"
                            Foreground="White"
                            FontSize="18"
                            Cursor="Hand"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="btnAdd_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnDelete"
                            Content="OBRIŠI"
                            Width="140"
                            Height="45"
                            Margin="0,0,12,0"
                            Background="#D92C41"
                            Foreground="White"
                            FontSize="18"
                            FontWeight="Bold"
                            ToolTip="Brisanje oznacenih legendi"
                            Cursor="Hand"
                            BorderThickness="0"
                            Click="btnDelete_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnExit"
                            Content="IZLAZ"
                            Width="140"
                            Height="45"
                            Background="#A68349"
                            Foreground="White"
                            Cursor="Hand"
                            FontSize="18"
                            FontWeight="Bold"
                            BorderThickness="0"
                            ToolTip="Nazad šefe"
                            Click="btnExit_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>