<Window x:Class="NBALegende.LegendDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NBALegende"
        mc:Ignorable="d"
        Title="Detalji NBA legende"
        Height="700"
        Width="950"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#EEE7D6">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Foreground" Value="#1B1B1B"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="#F8F2E3"
                CornerRadius="25"
                BorderBrush="#A68349"
                BorderThickness="3"
                Padding="22">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="DETALJAN PRIKAZ NBA LEGENDE"
                           FontSize="32"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!--namestisesliko-->
                    <Border Grid.Column="0"
                            Height="360"
                            Background="#F4E9C7"
                            BorderBrush="#A68349"
                            BorderThickness="2"
                            CornerRadius="12"
                            VerticalAlignment="Top">
                        <Image x:Name="imgLegend"
                                Width="300"
                                Height="220"
                                Stretch="Uniform"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                    </Border>

                    <!--podaci-->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                            Text="Ime i prezime"
                            FontSize="18"
                            FontWeight="Bold"
                            Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="1"
                            x:Name="txtFullName"
                            FontSize="22"
                            Margin="0,0,0,18"/>

                        <TextBlock Grid.Row="2"
                            Text="Broj dresa"
                            FontSize="18"
                            FontWeight="Bold"
                            Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="3"
                            x:Name="txtJerseyNumber"
                            FontSize="22"
                            Margin="0,0,0,18"/>

                        <TextBlock Grid.Row="4"
                            Text="Datum dodavanja"
                            FontSize="18"
                            FontWeight="Bold"
                            Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="5"
                            x:Name="txtDateAdded"
                            FontSize="20"
                            Margin="0,0,0,18"/>

                        <TextBlock Grid.Row="6"
                            Text="Biografija"
                            FontSize="18"
                            FontWeight="Bold"
                            Margin="0,0,0,8"/>

                        <Border Grid.Row="7"
                            Background="#FFFDF8"
                            BorderBrush="#A68349"
                            BorderThickness="1.5"
                            CornerRadius="10"
                            Padding="12"
                            MinHeight="200">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                    HorizontalScrollBarVisibility="Disabled">
                                <TextBlock x:Name="txtBiography"
                                    TextWrapping="Wrap"
                                    FontSize="16"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <Button x:Name="btnClose"
                        Grid.Row="2"
                        Content="ZATVORI"
                        Width="150"
                        Height="45"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0"
                        Background="#A68349"
                        Foreground="White"
                        FontSize="18"
                        FontFamily="Times New Roman"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="btnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>